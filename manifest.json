{
  "manifest_version": 3,
  "name": "Load Gmail Draft Button",
  "description": "Adds a Gmail draft button next to broker contact emails on load detail pages.",
  "version": "3.0.4",
  "permissions": ["identity", "storage"],
  "host_permissions": ["https://www.googleapis.com/*"],
  "icons": {
    "16": "icons/letter-16.png",
    "32": "icons/letter-32.png",
    "48": "icons/letter-48.png",
    "128": "icons/letter-128.png"
  },
  "action": {
    "default_title": "Gmail load tools",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/letter-16.png",
      "32": "icons/letter-32.png",
      "48": "icons/letter-48.png",
      "128": "icons/letter-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
